# SafeSpace Student Help Portal - Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/safespace

# Security Keys (Generate new ones for production)
JWT_SECRET=your-super-secret-jwt-key-here
SESSION_SECRET=your-session-secret-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SUBMISSION_LIMIT_MAX=5

# Email Configuration (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM=SafeSpace Support <noreply@safespace.edu>

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@safespace.edu

# Crisis Hotline Information
CRISIS_HOTLINE=988
CRISIS_TEXT=741741

# External Resources URLs
COUNSELING_CENTER_URL=https://your-school.edu/counseling
ACADEMIC_SUPPORT_URL=https://your-school.edu/tutoring
FINANCIAL_AID_URL=https://your-school.edu/financial-aid